[Unit]
Description=CoBien Launcher (main runtime)
After=graphical-session.target network-online.target
Wants=graphical-session.target network-online.target
PartOf=graphical-session.target
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
Type=simple
WorkingDirectory=%h/cobien/cobien-furniture-app-launcher
ExecStart=/bin/bash %h/cobien/cobien-furniture-app-launcher/cobien-launcher.sh --mode launch --non-interactive --yes --workspace %h/cobien --frontend-name cobien_FrontEnd --mqtt-name cobien_MQTT_Dictionnary --branch master
Restart=always
RestartSec=5
KillMode=mixed
TimeoutStopSec=20

[Install]
WantedBy=graphical-session.target
